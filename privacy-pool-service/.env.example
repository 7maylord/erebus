# Server
PORT=4021
NODE_ENV=development

# Stellar network
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# USDC Soroban contract address on testnet
USDC_CONTRACT=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# OZ Hosted Facilitator (no local relayer needed)
# Testnet API key → https://channels.openzeppelin.com/testnet/gen
# Mainnet API key → https://channels.openzeppelin.com/gen
FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
RELAYER_API_KEY=your-testnet-api-key-here

# Privacy pool keypair — fund this account with testnet USDC before running
# Generate: node -e "import('@stellar/stellar-sdk').then(s=>{ const kp=s.Keypair.random(); console.log('Secret:',kp.secret()); console.log('Public:',kp.publicKey()) })"
# 1. Activate: https://friendbot.stellar.org/?addr=YOUR_PUBLIC_KEY
# 2. Fund USDC: https://faucet.circle.com (select Stellar testnet)
POOL_STELLAR_SECRET=SB...your-pool-secret-key-here...

# Batching (seconds between outgoing payment runs)
BATCH_INTERVAL_SECONDS=30

# ── Demo script (test-pay.mjs) ────────────────────────────────────────────────
# Agent account that pays into the pool via x402 (needs USDC on testnet)
PAYER_SECRET=SB...your-agent-secret-key-here...

# Payee addresses to receive private payouts (comma-separated G... addresses)
# These are the recipients the pool will pay on behalf of the agent
DEMO_PAYEES=G...payee1...,G...payee2...,G...payee3...

# Server URL (set to Railway URL when running against deployed server)
SERVER_URL=http://localhost:4021
