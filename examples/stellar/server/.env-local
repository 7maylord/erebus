# Stellar public key (payee address that receives payments)
STELLAR_ADDRESS=

# Relayer plugin endpoint for x402 facilitator
FACILITATOR_URL=http://localhost:8080/api/v1/plugins/x402/call

# Auth key for the relayer
RELAYER_API_KEY=

# Server port (default: 4021)
PORT=4021

# Stellar network (default: stellar:pubnet)
# Use "stellar:testnet" for testnet
# STELLAR_NETWORK=stellar:pubnet
STELLAR_NETWORK=stellar:testnet
