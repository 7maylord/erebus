# Stellar secret key (starts with S) - must be funded on testnet
# Fund at: https://laboratory.stellar.org/#account-creator?network=test
STELLAR_PRIVATE_KEY=

# URL of the x402 server example
SERVER_URL=http://localhost:4021

# Number of parallel requests to fire
CONCURRENT_REQUESTS=5

# Stellar RPC URL (required for mainnet, optional for testnet)
# See https://developers.stellar.org/docs/data/apis/rpc/providers#publicly-accessible-apis
# STELLAR_RPC_URL=https://mainnet.sorobanrpc.com